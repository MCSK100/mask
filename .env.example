# Socket server (see VITE_SOCKET_URL in src/lib/socket.js if used)
# VITE_SOCKET_URL=https://your-api.example.com

# WebRTC TURN (recommended for video across strict NATs / different networks).
# Example: turn:global.turn.twilio.com:3478?transport=udp,turn:global.turn.twilio.com:3478?transport=tcp
# VITE_TURN_URLS=
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=

# Public site URL (optional; update public/sitemap.xml + index.html canonical if you change domain)
# VITE_SITE_URL=https://mask-six.vercel.app

# Shown on About / Contact
# VITE_CONTACT_EMAIL=you@yourdomain.com
